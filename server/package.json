{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "AGPL-3.0",
  "scripts": {
    "prebuild": "pnpm --filter @projectx/types build",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "sh -c 'export $(grep -v \"^#\" .env | xargs) 2>/dev/null; exec nest start --watch'",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate": "drizzle-kit migrate",
    "e2e:db:migrate": "DATABASE_URL=postgres://projectx:projectx@localhost:5432/projectx_e2e pnpm db:migrate",
    "db:migrate:runtime": "node dist/scripts/migrate.js",
    "e2e:db:prepare": "tsx src/scripts/db-prepare-e2e.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/scripts/db-seed.ts",
    "pretype-check": "pnpm --filter @projectx/types build",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "lint": "pnpm run lint:check",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run --exclude test/scanner-scenarios.e2e-spec.ts --exclude test/scanner-file-operations.e2e-spec.ts",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "e2e:run": "vitest run test/app-smoke.e2e-spec.ts"
  },
  "dependencies": {
    "7z-wasm": "^1.2.0",
    "@fastify/compress": "^8.3.1",
