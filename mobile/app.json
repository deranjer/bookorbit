{
  "expo": {
    "name": "BookOrbit",
    "slug": "bookorbit",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bookorbit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookorbit.mobile",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.bookorbit.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/images/icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "49ae972c-90a1-48af-b58f-6f3e8a445f11"
      },
      "router": {}
    },
    "owner": "deranjer"
  }
}
