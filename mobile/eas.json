{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EAS_FALLBACK_PACKAGE_MANAGER": "npm",
        "EAS_NO_FROZEN_LOCKFILE": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EAS_FALLBACK_PACKAGE_MANAGER": "npm",
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
